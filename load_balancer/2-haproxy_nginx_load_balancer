#!/usr/bin/env bash
# Load Balancer Configuration - Homework
# Configures HAProxy and Nginx to load balance between web-01 and web-02

# ========== HAProxy Configuration ==========
apt update && apt install haproxy -y

cat > /etc/haproxy/haproxy.cfg << 'HAPROXY'
global
    log /dev/log local0
    maxconn 2000
    daemon

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    retries 3
    timeout connect 5000ms
    timeout client  50000ms
    timeout server  50000ms

frontend http_front
    bind *:80
    default_backend http_back

backend http_back
    balance roundrobin
    server web-01 172.25.0.11:80 check
    server web-02 172.25.0.12:80 check
HAPROXY

service haproxy start

# ========== Nginx Load Balancer Configuration ==========
apt install nginx -y

cat > /etc/nginx/sites-available/default << 'NGINX'
upstream backend {
    server 172.25.0.11:80 weight=1;
    server 172.25.0.12:80 weight=1;
}

server {
    listen 80;
    location / {
        proxy_pass http://backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
NGINX

service nginx restart
